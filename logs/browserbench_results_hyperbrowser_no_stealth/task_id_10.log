  font-display: swap;
}

/* Glassdoor Sans */
/* These fonts are loaded after the initial font for performance reasons */

@font-face {
  font-family: 'Glassdoor Sans';
  src: url('https://www.glassdoor.com/assets/fonts/GlassdoorSans-Regular.woff2?v=20240110') format('woff2');
  font-weight: 400;
